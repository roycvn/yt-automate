# Copy to .env and fill in. NEVER commit the real .env.

# Claude API
ANTHROPIC_API_KEY=

# klipr batch API key (mint via klipr's scripts/mint-api-key.ts) — klipr_live_...
KLIPR_API_KEY=

# Dubbing / TTS
ELEVENLABS_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=

# Thumbnail image generation
IMAGE_API_KEY=

# YouTube Data + Analytics API (OAuth2 client + per-channel refresh tokens)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN_HINDI=
YOUTUBE_REFRESH_TOKEN_TELUGU=
